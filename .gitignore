.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Floorplan raw files (large images — not tracked)
floorplans/raw/*
!floorplans/raw/.gitkeep
floorplans/processed/*
!floorplans/processed/.gitkeep

# 3D scan files
scans/raw/*
!scans/raw/.gitkeep
scans/processed/*
!scans/processed/.gitkeep
