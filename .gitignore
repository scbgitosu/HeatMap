# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Streamlit
.streamlit/

# Survey data (keep structure, ignore actual data files)
survey_projects/**/*.csv
survey_projects/**/*.png
